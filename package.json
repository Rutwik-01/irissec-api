{
  "name": "irissec-api",
  "version": "1.0.0",
  "description": "IRIS — Incident Response Intelligence System REST API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "echo 'Build complete - no transpilation required for Node.js'",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 60
      }
    },
    "reporters": ["default", "jest-junit"],
    "coveragePathIgnorePatterns": ["/node_modules/"]
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^9.4.3",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.4"
  }
}
